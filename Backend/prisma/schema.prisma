// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

 
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
enum NotificationType {
  LIKE
  COMMENT
  REPLY
  FOLLOW
  ADMIN
}

enum PostStatus {
  DRAFT
  PUBLISHED
}
enum Role {
  USER
  GROOMER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}
        

model User {
  id            String   @id @default(uuid()) @db.Uuid
  googleId      String?  @unique
  name          String
  email         String   @unique
  password      String?
  role          Role     @default(USER)

  phone         String?
  city          String?
  pincode       String?

  latitude      Decimal? @db.Decimal(9, 6)
  longitude     Decimal? @db.Decimal(9, 6)

  photo         String?
  created_at    DateTime @default(now())
  isDeleted     Boolean  @default(false)

  groomer       Groomer?
  bookings      Booking[]
  reviews       Review[]
  complaints    Complaint[]
  pets          Pet[]

  posts         CommunityPost[]
  comments      Comment[]
  likes         Like[]
  bookmarks     Bookmark[]

  followers     Follow[] @relation("UserFollowers")
  following     Follow[] @relation("UserFollowing")

  feedItems     Feed[]

  notifications Notification[]
  sentNotifications Notification[] @relation("NotificationSender")
  @@map("users")
}

model Groomer {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @db.Uuid
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  isVerified        Boolean  @default(false)
  verificationStatus String  @default("pending") //pending, approved, rejected
  bio               String?
  yearsOfExperience Int?
  rating            Decimal? @db.Decimal(3, 2)
  totalReviews      Int      @default(0)
  
  documents         GroomerDocument[]
  services          GroomerService[]
  availability      Availability[]
  bookings          Booking[]
  wallet            GroomerWallet?
  payouts           Payout[]
  reviews           Review[]
  
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@map("groomers")
}

model GroomerDocument {
  id                String   @id @default(uuid()) @db.Uuid
  groomerId         String   @db.Uuid
  groomer           Groomer  @relation(fields: [groomerId], references: [id], onDelete: Cascade)
  
  documentType      String   // pancard, aadhar, license, certificate, etc
  documentUrl       String
  verificationStatus String  @default("pending") // pending, approved, rejected
  verificationNotes String?
  
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@map("groomer_documents")
}

model Service {
  id                String   @id @default(uuid()) @db.Uuid
  name              String
  description       String?
  duration          Int      // duration in minutes
  isActive          Boolean  @default(true)
  
  groomerServices   GroomerService[]
  invoiceItems      InvoiceItem[]
  bookingServices BookingService[]

  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@map("services")
}

model GroomerService {
  id                String   @id @default(uuid()) @db.Uuid
  groomerId         String   @db.Uuid
  groomer           Groomer  @relation(fields: [groomerId], references: [id], onDelete: Cascade)
  
  serviceId         String   @db.Uuid
  service           Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  
  customPrice       Decimal? @db.Decimal(10, 2)
  customDuration    Int?     // duration in minutes
  isActive          Boolean  @default(true)
  
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
  
  @@unique([groomerId, serviceId])
  @@map("groomer_services")
}

model Availability {
  id                String   @id @default(uuid()) @db.Uuid
  groomerId         String   @db.Uuid
  groomer           Groomer  @relation(fields: [groomerId], references: [id], onDelete: Cascade)
  
  dayOfWeek         Int      // 0 = Sunday, 6 = Saturday
  startTime         String   // HH:MM format
  endTime           String   // HH:MM format
  isAvailable       Boolean  @default(true)
  
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@map("availability")
}

model Booking {
  id              String        @id @default(uuid()) @db.Uuid
  
  userId          String        @db.Uuid
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  groomerId       String        @db.Uuid
  groomer         Groomer       @relation(fields: [groomerId], references: [id], onDelete: Cascade)

  petId           String        @db.Uuid
  pet             Pet           @relation(fields: [petId], references: [id], onDelete: Cascade)
  groomingProof GroomingProof?
  bookingDate     DateTime
  status          BookingStatus @default(PENDING)

  totalAmount     Decimal       @db.Decimal(10,2)

  bookingServices BookingService[]

  invoice         Invoice?
  complaints Complaint[]
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  @@index([userId])
  @@index([groomerId])
  @@index([status])
  @@index([bookingDate])
  @@map("bookings")
}


model GroomingProof {
  id                 String   @id @default(uuid()) @db.Uuid
  bookingId          String   @unique @db.Uuid
  booking            Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  verificationStatus String   @default("pending") // pending, approved, rejected
  adminComment       String?

  media              GroomingProofMedia[]

  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  @@map("grooming_proofs")
}
model GroomingProofMedia {
  id          String   @id @default(uuid()) @db.Uuid
  proofId     String   @db.Uuid
  proof       GroomingProof @relation(fields: [proofId], references: [id], onDelete: Cascade)

  url         String
  mediaType   String   // "image" or "video"
  stage       String   // "before" or "after"

  created_at  DateTime @default(now())

  @@map("grooming_proof_media")
}


model Review {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @db.Uuid
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  groomerId         String   @db.Uuid
  groomer           Groomer  @relation(fields: [groomerId], references: [id], onDelete: Cascade)
  
  rating            Int      // 1-5
  comment           String?
  
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@map("reviews")
}

model Complaint {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @db.Uuid
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  bookingId         String   @db.Uuid
  booking           Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  reason            String
  description       String
  status            String   @default("open") // open, in_review, resolved, rejected
  adminResponse     String?
  
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@map("complaints")
}

model Invoice {
  id                String   @id @default(uuid()) @db.Uuid
  bookingId         String   @unique @db.Uuid
  booking           Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  subtotal          Decimal  @db.Decimal(10, 2)
  platformFee       Decimal  @db.Decimal(10, 2)
  tax               Decimal  @db.Decimal(10, 2)
  totalAmount       Decimal  @db.Decimal(10, 2)
  status            String   @default("pending") // pending, paid, cancelled
  
  items             InvoiceItem[]
  addonCharges      AddonCharge[]
  payment           Payment?
  
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@map("invoices")
}

model InvoiceItem {
  id                String   @id @default(uuid()) @db.Uuid
  invoiceId         String   @db.Uuid
  invoice           Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  serviceId         String   @db.Uuid
  service           Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  
  quantity          Int      @default(1)
  price             Decimal  @db.Decimal(10, 2)

  @@map("invoice_items")
}

model AddonCharge {
  id                String   @id @default(uuid()) @db.Uuid
  invoiceId         String   @db.Uuid
  invoice           Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  description       String
  amount            Decimal  @db.Decimal(10, 2)

  @@map("addon_charges")
}

model Payment {
  id                String   @id @default(uuid()) @db.Uuid
  invoiceId         String   @unique @db.Uuid
  invoice           Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  paymentGateway    String   // razorpay, stripe
  transactionId     String   @unique
  status            String   @default("pending") // pending, completed, failed, refunded
  amount            Decimal  @db.Decimal(10, 2)
  
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@map("payments")
}

model GroomerWallet {
  id                String   @id @default(uuid()) @db.Uuid
  groomerId         String   @unique @db.Uuid
  groomer           Groomer  @relation(fields: [groomerId], references: [id], onDelete: Cascade)
  
  balance           Decimal  @default(0) @db.Decimal(10, 2)
  totalEarnings     Decimal  @default(0) @db.Decimal(10, 2)
  
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@map("groomer_wallets")
}

model Payout {
  id                String   @id @default(uuid()) @db.Uuid
  groomerId         String   @db.Uuid
  groomer           Groomer  @relation(fields: [groomerId], references: [id], onDelete: Cascade)
  
  amount            Decimal  @db.Decimal(10, 2)
  status            String   @default("pending") // pending, processing, completed, failed
  bankAccount       String?
  
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@map("payouts")
}


model Pet {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name          String
  species       String   // dog, cat, etc
  breed         String?
  age           Int?
  weight        Decimal? @db.Decimal(5,2)
  medicalNotes  String?
  photo         String?

  bookings      Booking[]
  isDeleted Boolean @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  @@unique([userId, name, species])
  
  @@map("pets")
}

model CommunityPost {
 id String @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  content   String?
  createdAt DateTime @default(now())
  imageUrl  String?
  user      User @relation(fields: [userId], references: [id])

  comments  Comment[]
  likes     Like[]
  bookmarks Bookmark[]

  feeds Feed[]
  notifications Notification[]
}



model Comment {
  id String @id @default(uuid()) @db.Uuid
  postId    String   @db.Uuid
  userId    String   @db.Uuid
  comment   String
  parentId  String?  @db.Uuid
  createdAt DateTime @default(now())

  post      CommunityPost @relation(fields: [postId], references: [id])
  user      User          @relation(fields: [userId], references: [id])

  replies   Comment[] @relation("CommentReplies")
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])

  notifications Notification[]
}
model Like {
  id      String @id @default(uuid())
  userId  String @db.Uuid
  postId  String @db.Uuid

  user User @relation(fields: [userId], references: [id])
  post CommunityPost @relation(fields: [postId], references: [id])

  @@unique([userId, postId])
}

model Bookmark {
  id      String @id @default(uuid())
  userId  String @db.Uuid
  postId  String @db.Uuid

  user User @relation(fields: [userId], references: [id])
  post CommunityPost @relation(fields: [postId], references: [id])

  @@unique([userId, postId])
}

model Follow {
  id           String @id @default(uuid())
 
  followerId   String @db.Uuid
  followingId  String @db.Uuid

  follower     User @relation("UserFollowing", fields: [followerId], references: [id])
  following    User @relation("UserFollowers", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

model Feed {
  id String @id @default(uuid()) @db.Uuid
  userId    String  @db.Uuid
  postId    String  @db.Uuid
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  post CommunityPost @relation(fields: [postId], references: [id])
}

model BookingService {
  id         String   @id @default(uuid()) @db.Uuid

  bookingId  String   @db.Uuid
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  serviceId  String   @db.Uuid
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  priceAtBooking Decimal @db.Decimal(10,2)

  created_at DateTime @default(now())

  @@index([serviceId])
  @@index([bookingId])
  @@map("booking_services")
}

model Notification {
  id String @id @default(uuid()) @db.Uuid

  userId      String?   @db.Uuid     // null for broadcast notifications
  senderId    String?  @db.Uuid
  postId      String?  @db.Uuid
  commentId   String? @db.Uuid

  type        NotificationType
  title       String?
  message     String

  isBroadcast Boolean  @default(false)
  isRead      Boolean  @default(false)

  createdAt   DateTime @default(now())

  user        User? @relation(fields: [userId], references: [id])
  sender      User? @relation("NotificationSender", fields: [senderId], references: [id])

  post        CommunityPost? @relation(fields: [postId], references: [id])
  comment     Comment? @relation(fields: [commentId], references: [id])

  @@index([userId])
}